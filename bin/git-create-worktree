#!/usr/bin/env bash
# ╭──────────────────────────────────────────────────────────────────────────────╮
# │                                                                              │
# │  ██╗    ██╗  ██████╗ ██████╗ ██╗  ██╗    ████████╗██████╗ ███████╗███████╗  │
# │  ██║    ██║ ██╔═══██╗██╔══██╗██║ ██╔╝    ╚══██╔══╝██╔══██╗██╔════╝██╔════╝  │
# │  ██║ █╗ ██║ ██║   ██║██████╔╝█████╔╝        ██║   ██████╔╝█████╗  █████╗    │
# │  ██║███╗██║ ██║   ██║██╔══██╗██╔═██╗         ██║   ██╔══██╗██╔══╝  ██╔══╝   │
# │  ╚███╔███╔╝ ╚██████╔╝██║  ██║██║  ██╗        ██║   ██║  ██║███████╗███████╗  │
# │   ╚══╝╚══╝   ╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝        ╚═╝   ╚═╝  ╚═╝╚══════╝╚══════╝ │
# │                                                                              │
# │              Create a new worktree with upstream tracking                   │
# │                                                                              │
# ╰──────────────────────────────────────────────────────────────────────────────╯

set -Eeuo pipefail
trap cleanup SIGINT SIGTERM ERR EXIT

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Configuration                                                                │
# └──────────────────────────────────────────────────────────────────────────────┘

# shellcheck disable=SC2034
script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd -P)

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Colors & Styling                                                             │
# └──────────────────────────────────────────────────────────────────────────────┘

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly MAGENTA='\033[0;35m'
readonly CYAN='\033[0;36m'
readonly WHITE='\033[1;37m'
readonly GRAY='\033[0;90m'
readonly NC='\033[0m'

# Nerd Font Icons
readonly ICON_CHECK=""
readonly ICON_CROSS=""
readonly ICON_ARROW=""
readonly ICON_WARN=""
readonly ICON_INFO=""
readonly ICON_GIT=""
readonly ICON_BRANCH=""
readonly ICON_FOLDER="󰉋"
readonly ICON_PUSH="󰕒"
readonly ICON_ROCKET="󱓞"
readonly ICON_GEAR="󰒓"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Helper Functions                                                             │
# └──────────────────────────────────────────────────────────────────────────────┘

print_header() {
    echo ""
    echo -e "${CYAN}╭────────────────────────────────────────────────────────────╮${NC}"
    echo -e "${CYAN}│${NC}  ${WHITE}$1${NC}"
    echo -e "${CYAN}╰────────────────────────────────────────────────────────────╯${NC}"
}

print_section() {
    echo ""
    echo -e "${MAGENTA}  $1${NC}"
    echo -e "${GRAY}  ──────────────────────────────────────────────────────────${NC}"
}

print_step()    { echo -e "  ${GRAY}${ICON_ARROW}${NC} $1"; }
print_success() { echo -e "  ${GREEN}${ICON_CHECK}${NC} $1"; }
print_error()   { echo -e "  ${RED}${ICON_CROSS}${NC} $1" >&2; }
print_warn()    { echo -e "  ${YELLOW}${ICON_WARN}${NC} $1"; }
print_info()    { echo -e "  ${BLUE}${ICON_INFO}${NC} $1"; }

die() {
    print_error "$1"
    exit "${2-1}"
}

cleanup() {
    trap - SIGINT SIGTERM ERR EXIT
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Usage                                                                        │
# └──────────────────────────────────────────────────────────────────────────────┘

usage() {
    echo ""
    echo -e "${WHITE}Usage:${NC} $(basename "${BASH_SOURCE[0]}") ${GRAY}[-h] [-v] [-b <branch>] [-B <base>] [-p <prefix>] [-N]${NC} ${CYAN}<path>${NC}"
    echo ""
    echo -e "  Create a new git worktree with optional upstream tracking."
    echo ""
    echo -e "${WHITE}Options:${NC}"
    echo -e "  ${CYAN}-h, --help${NC}                    Print this help and exit"
    echo -e "  ${CYAN}-v, --verbose${NC}                 Print script debug info"
    echo -e "  ${CYAN}-b, --branch${NC}  ${GRAY}<name>${NC}          Branch name to create or checkout"
    echo -e "  ${CYAN}-B, --base${NC}    ${GRAY}<branch>${NC}        Base branch for new worktree ${GRAY}(default: origin/main)${NC}"
    echo -e "  ${CYAN}-p, --prefix${NC}  ${GRAY}<prefix>${NC}        Prefix applied to the branch name ${GRAY}(default: <github.user>/)${NC}"
    echo -e "  ${CYAN}-N, --no-create-upstream${NC}      Skip creating or setting upstream"
    echo ""
    echo -e "${WHITE}Steps performed:${NC}"
    echo -e "  ${GRAY}1.${NC} Create worktree from base branch (or attach to existing branch)"
    echo -e "  ${GRAY}2.${NC} Push branch to remote and configure upstream tracking"
    echo ""
    exit 0
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Argument Parsing                                                             │
# └──────────────────────────────────────────────────────────────────────────────┘

parse_params() {
    create_upstream=1
    prefix="$(git config github.user 2>/dev/null || true)/"
    base='origin/main'
    branch=''

    while :; do
        case "${1-}" in
        -h | --help)               usage ;;
        -v | --verbose)            set -x ;;
        --no-color)                : ;;
        -N | --no-create-upstream) create_upstream=0 ;;
        -b | --branch)
            branch="${2-}"
            shift
            ;;
        -B | --base)
            base="${2-}"
            shift
            ;;
        -p | --prefix)
            prefix="${2-}"
            shift
            ;;
        -?*) die "Unknown option: $1" ;;
        *)   break ;;
        esac
        shift
    done

    args=("$@")
    [[ ${#args[@]} -eq 0 ]] && die "Missing required argument: worktree path"

    if [[ -z "$branch" ]]; then
        branch="${prefix}${args[0]}"
    fi

    worktree="${args[0]}"

    return 0
}

parse_params "$@"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Pre-flight Checks                                                            │
# └──────────────────────────────────────────────────────────────────────────────┘

print_header "${ICON_GIT} git-create-worktree"

print_section "${ICON_GEAR} Configuration"
print_info "Worktree:  ${WHITE}$worktree${NC}"
print_info "Branch:    ${WHITE}$branch${NC}"
print_info "Base:      ${GRAY}$base${NC}"
[[ $create_upstream -eq 1 ]] \
    && print_info "Upstream:  ${GREEN}enabled${NC}" \
    || print_info "Upstream:  ${YELLOW}disabled (--no-create-upstream)${NC}"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Execution Steps                                                              │
# └──────────────────────────────────────────────────────────────────────────────┘

# ── Step 1/2: Create worktree ─────────────────────────────────────────────────
print_section "${ICON_FOLDER} [1/2] Creating worktree"

if [[ -n "$(git branch --list "$branch")" ]]; then
    print_step "Branch ${CYAN}$branch${NC} exists locally — attaching worktree"
    git worktree add "$worktree" "$branch"
else
    print_step "Creating new branch ${CYAN}$branch${NC} from ${GRAY}$base${NC}"
    git worktree add -b "$branch" "$worktree" "$base"
fi

worktree_path="$(pwd)/$worktree"
print_success "Worktree created at ${GRAY}$worktree_path${NC}"

# ── Step 2/2: Configure upstream tracking ────────────────────────────────────
print_section "${ICON_PUSH} [2/2] Configuring upstream"

update_remote() {
    local target_branch="$1"

    if [[ $create_upstream -eq 0 ]]; then
        print_warn "Upstream skipped (--no-create-upstream)"
        return 0
    fi

    print_step "Checking remote for branch ${CYAN}$target_branch${NC}"

    if [[ -z "$(git ls-remote --heads origin "$target_branch")" ]]; then
        print_step "Remote branch not found — pushing to origin"
        git push -u origin "$target_branch"
    else
        print_step "Remote branch exists — setting upstream"
        git branch --set-upstream-to="origin/$target_branch"
    fi
}

cd "$worktree"
update_remote "$branch"
print_success "Upstream tracking configured"

# ── Optional: Language / framework setup (uncomment as needed) ───────────────
# print_section "${ICON_GEAR} Additional Setup"
# print_step "Setting Node version..."    && fnm use < .nvmrc                  && print_success "Node version set"
# print_step "Installing dependencies..." && npm --no-progress --silent install && print_success "Dependencies installed"
# print_step "Building project..."        && npm run --silent build             && print_success "Build complete"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Summary                                                                      │
# └──────────────────────────────────────────────────────────────────────────────┘

print_header "${ICON_ROCKET} Worktree ready"

echo -e "  ${GREEN}${ICON_CHECK}${NC} ${WHITE}$branch${NC}  ${GRAY}→  origin/$branch${NC}"
echo -e "  ${CYAN}${ICON_FOLDER}${NC} ${GRAY}$worktree_path${NC}"
echo ""
print_info "cd ${CYAN}$worktree_path${NC} to start working"
echo ""
