#!/usr/bin/env bash
# ╭──────────────────────────────────────────────────────────────────────────────╮
# │                                                                              │
# │  ██╗███████╗███████╗██╗   ██╗███████╗    ██╗    ██╗ ██████╗ ██████╗ ██╗  ██╗ │
# │  ██║██╔════╝██╔════╝██║   ██║██╔════╝    ██║    ██║██╔═══██╗██╔══██╗██║ ██╔╝ │
# │  ██║███████╗███████╗██║   ██║███████╗    ██║ █╗ ██║██║   ██║██████╔╝█████╔╝  │
# │  ██║╚════██║╚════██║██║   ██║╚════██║    ██║███╗██║██║   ██║██╔══██╗██╔═██╗  │
# │  ██║███████║███████║╚██████╔╝███████║    ╚███╔███╔╝╚██████╔╝██║  ██║██║  ██╗ │
# │  ╚═╝╚══════╝╚══════╝ ╚═════╝ ╚══════╝     ╚══╝╚══╝  ╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝ │
# │                                                                              │
# │              Link GitHub issue to a new git worktree                        │
# │                                                                              │
# ╰──────────────────────────────────────────────────────────────────────────────╯

set -Eeuo pipefail
trap cleanup SIGINT SIGTERM ERR EXIT

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Configuration                                                                │
# └──────────────────────────────────────────────────────────────────────────────┘

# shellcheck disable=SC2034
script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd -P)
script_name=$(basename "${BASH_SOURCE[0]}")

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Colors & Styling                                                             │
# └──────────────────────────────────────────────────────────────────────────────┘

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly MAGENTA='\033[0;35m'
readonly CYAN='\033[0;36m'
readonly WHITE='\033[1;37m'
readonly GRAY='\033[0;90m'
readonly NC='\033[0m'

# Nerd Font Icons
readonly ICON_CHECK=""
readonly ICON_CROSS=""
readonly ICON_ARROW=""
readonly ICON_WARN=""
readonly ICON_INFO=""
readonly ICON_GIT=""
readonly ICON_BRANCH=""
readonly ICON_FOLDER="󰉋"
readonly ICON_ISSUE=""
readonly ICON_ROCKET="󱓞"
readonly ICON_GEAR="󰒓"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Helper Functions                                                             │
# └──────────────────────────────────────────────────────────────────────────────┘

print_header() {
    echo ""
    echo -e "${CYAN}╭────────────────────────────────────────────────────────────╮${NC}"
    echo -e "${CYAN}│${NC}  ${WHITE}$1${NC}"
    echo -e "${CYAN}╰────────────────────────────────────────────────────────────╯${NC}"
}

print_section() {
    echo ""
    echo -e "${MAGENTA}  $1${NC}"
    echo -e "${GRAY}  ──────────────────────────────────────────────────────────${NC}"
}

print_step()    { echo -e "  ${GRAY}${ICON_ARROW}${NC} $1"; }
print_success() { echo -e "  ${GREEN}${ICON_CHECK}${NC} $1"; }
print_error()   { echo -e "  ${RED}${ICON_CROSS}${NC} $1" >&2; }
print_warn()    { echo -e "  ${YELLOW}${ICON_WARN}${NC} $1"; }
print_info()    { echo -e "  ${BLUE}${ICON_INFO}${NC} $1"; }

die() {
    print_error "$1"
    exit "${2-1}"
}

cleanup() {
    trap - SIGINT SIGTERM ERR EXIT
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Usage                                                                        │
# └──────────────────────────────────────────────────────────────────────────────┘

usage() {
    echo ""
    echo -e "${WHITE}Usage:${NC} $script_name ${GRAY}[-h] [-v] [-r <repo>] [-B <base>] [-p <prefix>]${NC} ${CYAN}<issue> <slug>${NC}"
    echo ""
    echo -e "  Link a GitHub issue to a new git worktree."
    echo ""
    echo -e "${WHITE}Arguments:${NC}"
    echo -e "  ${CYAN}<issue>${NC}                GitHub issue number (e.g., 1, 42)"
    echo -e "  ${CYAN}<slug>${NC}                 Short description (e.g., base-snapshot, login-fix)"
    echo ""
    echo -e "${WHITE}Options:${NC}"
    echo -e "  ${CYAN}-h, --help${NC}             Print this help and exit"
    echo -e "  ${CYAN}-v, --verbose${NC}          Print script debug info"
    echo -e "  ${CYAN}-r, --repo${NC}    ${GRAY}<path>${NC}    Repository root directory ${GRAY}(default: current directory)${NC}"
    echo -e "  ${CYAN}-B, --base${NC}    ${GRAY}<branch>${NC}  Base branch for new worktree ${GRAY}(default: origin/main)${NC}"
    echo -e "  ${CYAN}-p, --prefix${NC}  ${GRAY}<prefix>${NC}  Prefix for branch name ${GRAY}(default: <github.user>/)${NC}"
    echo ""
    echo -e "${WHITE}Steps performed:${NC}"
    echo -e "  ${GRAY}1.${NC} Validate GitHub CLI is installed and authenticated"
    echo -e "  ${GRAY}2.${NC} Fetch issue details from GitHub"
    echo -e "  ${GRAY}3.${NC} Create worktree linked to issue"
    echo -e "  ${GRAY}4.${NC} Display next steps for the user"
    echo ""
    exit 0
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Argument Parsing                                                             │
# └──────────────────────────────────────────────────────────────────────────────┘

parse_params() {
    prefix=""
    base='origin/main'
    repo_dir=''
    issue_num=''
    slug=''

    while :; do
        case "${1-}" in
        -h | --help)     usage ;;
        -v | --verbose)  set -x ;;
        --no-color)      : ;;
        -r | --repo)
            repo_dir="${2-}"
            shift
            ;;
        -B | --base)
            base="${2-}"
            shift
            ;;
        -p | --prefix)
            prefix="${2-}"
            shift
            ;;
        -?*) die "Unknown option: $1" ;;
        *)   break ;;
        esac
        shift
    done

    args=("$@")
    [[ ${#args[@]} -lt 2 ]] && die "Missing required arguments: <issue> <slug>"

    issue_num="${args[0]}"
    slug="${args[1]}"

    # Validate issue_num is numeric
    if ! [[ "$issue_num" =~ ^[0-9]+$ ]]; then
        die "Invalid issue number: ${CYAN}$issue_num${NC}. Must be numeric."
    fi

    return 0
}

parse_params "$@"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Pre-flight Checks                                                            │
# └──────────────────────────────────────────────────────────────────────────────┘

print_header "${ICON_ISSUE} $script_name"

# Check if GitHub CLI is installed
print_section "${ICON_GEAR} [1/4] Checking dependencies"
if ! command -v gh &> /dev/null; then
    die "GitHub CLI (${CYAN}gh${NC}) is not installed or not in PATH. Install it from: https://cli.github.com"
fi
print_success "GitHub CLI found"

# Check if git is installed
if ! command -v git &> /dev/null; then
    die "Git is not installed or not in PATH"
fi
print_success "Git found"

# Check if git-create-worktree script exists
if [[ ! -f "$script_dir/git-create-worktree" ]]; then
    die "git-create-worktree script not found at ${GRAY}$script_dir/git-create-worktree${NC}"
fi
print_success "git-create-worktree found"

# Navigate to repository if specified
if [[ -n "$repo_dir" ]]; then
    if [[ ! -d "$repo_dir" ]]; then
        die "Repository directory not found: ${GRAY}$repo_dir${NC}"
    fi
    cd "$repo_dir" || die "Failed to change to repository directory: ${GRAY}$repo_dir${NC}"
fi

# Verify we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    die "Not a git repository. Use ${CYAN}-r, --repo${NC} to specify the repository path."
fi

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Fetch Issue Information                                                      │
# └──────────────────────────────────────────────────────────────────────────────┘

print_section "${ICON_ISSUE} [2/4] Fetching issue #$issue_num from GitHub"

# Try to get issue information
issue_data=$(gh issue view "$issue_num" --json "number,title,state" 2>/dev/null) || {
    die "Could not fetch issue #${CYAN}$issue_num${NC}. Does it exist? (Check your repo context with ${CYAN}gh repo set-default${NC})"
}

# Parse issue data
issue_title=$(echo "$issue_data" | jq -r '.title')
issue_state=$(echo "$issue_data" | jq -r '.state')

print_success "Issue fetched successfully"
print_info "Title:  ${WHITE}$issue_title${NC}"
print_info "State:  ${CYAN}$issue_state${NC}"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Create Worktree                                                              │
# └──────────────────────────────────────────────────────────────────────────────┘

print_section "${ICON_FOLDER} [3/4] Creating worktree"

branch_name="${prefix}issue/$issue_num-$slug"
worktree_name="$issue_num-$slug"

print_info "Branch: ${CYAN}$branch_name${NC}"
print_info "Slug:   ${CYAN}$slug${NC}"

# Call git-create-worktree script
"$script_dir/git-create-worktree" \
    -r "$repo_dir" \
    -B "$base" \
    -b "$branch_name" \
    -p "" \
    "$worktree_name" || die "Failed to create worktree"

# Construct the full path to the worktree
# repo_dir is like ~/Work/fake/dev, we go up one level to ~/Work/fake/
repo_parent="$(dirname "$repo_dir")"
worktree_full_path="$repo_parent/$worktree_name"

print_success "Worktree created at ${GRAY}$worktree_full_path${NC}"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Display Next Steps                                                           │
# └──────────────────────────────────────────────────────────────────────────────┘

print_section "${ICON_ROCKET} [4/4] Next Steps"

echo -e "  ${GREEN}${ICON_CHECK}${NC} ${WHITE}Issue #$issue_num${NC}       ${GRAY}→  $issue_title${NC}"
echo -e "  ${CYAN}${ICON_FOLDER}${NC} ${GRAY}$worktree_full_path${NC}"
echo -e "  ${CYAN}${ICON_BRANCH}${NC} ${WHITE}$branch_name${NC}       ${GRAY}→  origin/$branch_name${NC}"
echo ""

print_info "You are now in: ${CYAN}$worktree_full_path${NC}"
echo ""

echo -e "  ${WHITE}📝 To start working:${NC}"
echo -e "     cd ${CYAN}$worktree_full_path${NC}"
echo -e "     # Make your changes"
echo -e "     git add ."
echo -e "     git commit -m 'Your message'"
echo ""

echo -e "  ${WHITE}🔗 To create a Pull Request:${NC}"
echo -e "     gh pr create --title \"${issue_title}\" \\"
echo -e "                  --body \"Closes #${issue_num}\""
echo ""

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Summary                                                                      │
# └──────────────────────────────────────────────────────────────────────────────┘

print_header "${ICON_ROCKET} Issue worktree ready"
echo ""
