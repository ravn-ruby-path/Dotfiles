#!/usr/bin/env bash

# ═══════════════════════════════════════════════════════════════════════════════
# git-bare-clone — Clone a repo as bare and set up all worktrees with tracking
# ═══════════════════════════════════════════════════════════════════════════════
#
# Bare objects are stored in:  $BARE_HOME/<repo>       (~/.local/share/git-bare/<repo>)
# Worktrees are created in:    $WORKTREES_HOME/<repo>  (~/Work/<repo>)
#
# After cloning, all remote branches are available as worktrees with
# upstream tracking configured, ready for git pull/push.

set -Eeuo pipefail
trap cleanup SIGINT SIGTERM ERR EXIT

BARE_HOME="${BARE_HOME:-$HOME/.local/share/git-bare}"
WORKTREES_HOME="${WORKTREES_HOME:-$HOME/Work}"

usage() {
  cat <<EOF
Usage: $(basename "${BASH_SOURCE[0]}") [-h] [-v] [-w <path>] <repository>

Clone a bare git repo and create all worktrees with remote tracking configured.

Locations (override via environment variables or flags):
  Bare objects:  \$BARE_HOME/<repo>       (default: ~/.local/share/git-bare/<repo>)
  Worktrees:     \$WORKTREES_HOME/<repo>  (default: ~/Work/<repo>)

Available options:

-h, --help           Print this help and exit
-v, --verbose        Print script debug info
-w, --worktrees-dir  Override worktrees base directory
EOF
  exit
}

cleanup() {
  trap - SIGINT SIGTERM ERR EXIT
}

setup_colors() {
  if [[ -t 2 ]] && [[ -z "${NO_COLOR-}" ]] && [[ "${TERM-}" != "dumb" ]]; then
    NOFORMAT='\033[0m' RED='\033[0;31m' GREEN='\033[0;32m' ORANGE='\033[0;33m' BLUE='\033[0;34m' PURPLE='\033[0;35m' CYAN='\033[0;36m' YELLOW='\033[1;33m'
  else
    NOFORMAT='' RED='' GREEN='' ORANGE='' BLUE='' PURPLE='' CYAN='' YELLOW=''
  fi
}

msg() {
  echo >&2 -e "${1-}"
}

die() {
  local msg=$1
  local code=${2-1}
  msg "$msg"
  exit "$code"
}

parse_params() {
  worktrees_base="$WORKTREES_HOME"

  while :; do
    case "${1-}" in
    -h | --help) usage ;;
    -v | --verbose) set -x ;;
    --no-color) NO_COLOR=1 ;;
    -w | --worktrees-dir)
        worktrees_base="${2-}"
        shift
        ;;
    -?*) die "Unknown option: $1" ;;
    *) break ;;
    esac
    shift
  done

  args=("$@")
  [[ ${#args[@]} -eq 0 ]] && die "Missing required argument: repository URL"

  return 0
}

parse_params "$@"
setup_colors

repo_url="${args[0]}"
repo_name="$(basename "$repo_url" .git)"
bare_dir="$BARE_HOME/$repo_name"
worktrees_dir="$worktrees_base/$repo_name"

[[ -d "$bare_dir" ]]      && die "${RED}Error:${NOFORMAT} Bare repo already exists at '$bare_dir'"
[[ -d "$worktrees_dir" ]] && die "${RED}Error:${NOFORMAT} Worktrees dir already exists at '$worktrees_dir'"

msg "${CYAN}Repository:${NOFORMAT} $repo_name"
msg "${CYAN}Bare:       ${NOFORMAT} $bare_dir"
msg "${CYAN}Worktrees:  ${NOFORMAT} $worktrees_dir"
msg ""

# ── 1. Clone bare ─────────────────────────────────────────────────────────────
msg "${YELLOW}[1/5] Cloning bare repository...${NOFORMAT}"
mkdir -p "$BARE_HOME"
git clone --bare "$repo_url" "$bare_dir"

# ── 2. Configure fetch refspec ────────────────────────────────────────────────
pushd "$bare_dir" > /dev/null
msg "${YELLOW}[2/5] Configuring remote fetch refs...${NOFORMAT}"
git config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"

# ── 3. Fetch all remote tracking refs ─────────────────────────────────────────
msg "${YELLOW}[3/5] Fetching remote tracking refs...${NOFORMAT}"
git fetch origin
popd > /dev/null

# ── 4. Create worktrees directory with .git pointer ───────────────────────────
msg "${YELLOW}[4/5] Setting up worktrees directory...${NOFORMAT}"
mkdir -p "$worktrees_dir"
echo "gitdir: $bare_dir" > "$worktrees_dir/.git"

# ── 5. Create all worktrees with upstream tracking ────────────────────────────
msg "${YELLOW}[5/5] Creating worktrees for all remote branches...${NOFORMAT}"
mapfile -t branches < <(
  git --git-dir="$bare_dir" for-each-ref \
    --format='%(refname)' \
    refs/remotes/origin/ \
    | grep -v 'refs/remotes/origin/HEAD' \
    | sed 's|^refs/remotes/origin/||'
)

pushd "$worktrees_dir" > /dev/null
for branch in "${branches[@]}"; do
  msg "  ${BLUE}→${NOFORMAT} $branch"
  git worktree add "$branch" "$branch"
  git -C "$branch" branch --set-upstream-to="origin/$branch" "$branch"
done
popd > /dev/null

msg ""
msg "${GREEN}✓ Done! All worktrees ready.${NOFORMAT}"
msg ""
msg "  ${CYAN}$worktrees_dir/${NOFORMAT}"
for branch in "${branches[@]}"; do
  msg "    ${GREEN}✓${NOFORMAT} $branch  →  origin/$branch"
done
msg ""
msg "  cd ${CYAN}$worktrees_dir/<branch>${NOFORMAT} to start working"
