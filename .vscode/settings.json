{
  // ──── Editor ────────────────────────────────────────────────
  "editor.renderWhitespace": "trailing",
  "editor.formatOnSave": true,
  // ──── Nix: Formatter (alejandra) ────────────────────────────
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nil",
  "nix.formatterPath": "alejandra",
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide",
    "editor.formatOnSave": true
  },
  // ──── Nix: Linter (statix → Problems panel) ─────────────────
  // statix runs via task on folder open and manually (Ctrl+Shift+B)
  // nil LSP handles real-time diagnostics (syntax, undefined vars)
  "task.allowAutomaticTasksInFolder": "on",
  "nix.serverSettings": {
    "nil": {
      "diagnostics": {
        "ignored": []
      },
      "formatting": {
        "command": [
          "alejandra",
          "--quiet",
          "-"
        ]
      }
    }
  }
}